---
import Section from "./Section.astro";
import { getBrowseDimensions } from "@/utils/browse";
import { getBrowseValuesForEntry } from "@/utils/browse";
import type { Post, Note } from "@/types";

interface Props {
  entry: Post | Note;
}

const { entry } = Astro.props;

const dimensions = await getBrowseDimensions();
---
<Section title="Explore related">
  <dl class="grid grid-cols-[max-content_1fr] gap-x-4 gap-y-2">
    {dimensions.map((dimension) => {
      const values = getBrowseValuesForEntry(entry, dimension.key);

      if (values.length === 0) return null;

      return (
        <>
          <dt class="text-sm text-muted-foreground">
            {dimension.title}
          </dt>

          <dd class="text-sm">
            {values.map((value, index) => (
              <>
                <a
                  href={`/browse/${dimension.slug}/${value.slug}`}
                  class="title-link"
                >
                  {value.value}
                </a>

                {index < values.length - 1 && (
                  <span class="text-muted-foreground"> · </span>
                )}
              </>
            ))}
          </dd>
        </>
      );
    })}
  </dl>
</Section>