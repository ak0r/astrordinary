---
import BaseLayout from "@/layouts/BaseLayout.astro";
import PageHeader from "@/components/PageHeader.astro";
import PostFeed from "@/components/Feed.astro";
import { getAllPosts } from "@/utils/content";
import {
  getBrowseValues,
  filterBrowseEntries,
} from "@/utils/browse";

import { getBrowseDimensions } from "@/utils/browse";

const posts = await getAllPosts();

export async function getStaticPaths() {
  const posts = await getAllPosts();
  const dimensions = await getBrowseDimensions();
  return dimensions.flatMap((dimension) =>
    getBrowseValues(posts, dimension.key).map((value) => ({
      params: {
        slug: dimension.slug,
        value: value.slug,
      },
      props: {
        dimension,
        browseValue: value,
      },
    })),
  );
}

const {
  dimension,
  browseValue,
} = Astro.props;

const filteredPosts = filterBrowseEntries(
  posts,
  dimension.key,
  browseValue.slug,
);
---

<BaseLayout
  title={browseValue.value}
  description={`${filteredPosts.length} posts`}
>
  <div class="page-width">
    <PageHeader
      title={browseValue.value}
      lede=`Browse by ${dimension.title}`
    />

    <PostFeed
      entries={filteredPosts}
    />
  </div>

</BaseLayout>