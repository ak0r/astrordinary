---
import BaseLayout from "@/layouts/BaseLayout.astro";
import PageHeader from "@/components/PageHeader.astro";
import Section from "@/components/Section.astro";
import BrowseValueList from "@/components/BrowseValueList.astro";
import { getAllEntries } from "@/utils/content";
import { getMetaValues } from "@/utils/browse";
import { getConfig } from "@/utils/config";
import { getAssetPath } from "@/utils/url";
import type { BrowseIndexConfig } from "@/types";

export async function getStaticPaths() {
  const siteConfig = await getConfig();
  const indexes = siteConfig.browse?.indexes ?? [];

  return indexes.map((index) => ({
    params: { slug: index.slug },
    props: { index },
  }));
}

interface Props {
  index: BrowseIndexConfig;
}

const { index } = Astro.props as Props;
const allEntries = await getAllEntries();
const values = getMetaValues(allEntries, index.key);

---
<BaseLayout title={index.title}>
  <div class="page-width">
    <PageHeader
      title=`${index.title}`
      lede=`Browse articles and notes by ${index.title}`
    />
    <BrowseValueList
      items={values.map(({ value, slug }) => ({
        label: value,
        href: getAssetPath(`browse/${index.slug}/${slug}`),
      }))}
    />
  </div>
</BaseLayout>